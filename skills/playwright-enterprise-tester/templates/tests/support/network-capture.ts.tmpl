// Silent failure detection for network: captures requestfailed and HTTP status >= 400.
// Fails the test when forbidden statuses occur (per runner mode + allowlist).
//
// Usage: import { test, expect } from './support/network-capture';

import { test as base, expect } from '@playwright/test';

type NetworkAllowlistEntry = { type: 'requestfailed' | 'status'; urlRegex: string };

const DEFAULT_ALLOWLIST: NetworkAllowlistEntry[] = [
  { type: 'requestfailed', urlRegex: '/favicon\\.ico$' },
  { type: 'status', urlRegex: '/favicon\\.ico$' },
];

const isCI = !!process.env.CI || process.env.PWTEST_RUNNER_MODE === 'ci';
const failOnRequestFailed = isCI; // enforced only in CI by default
const failOnHttpError = isCI;
const httpErrorThreshold = 500; // 5xx fails, 4xx is warning

function isAllowlisted(
  type: 'requestfailed' | 'status',
  url: string,
  allowlist: NetworkAllowlistEntry[]
): boolean {
  return allowlist.some((e) => e.type === type && new RegExp(e.urlRegex).test(url));
}

type NetworkCapture = {
  requestFailed: Array<{ url: string; failure: string | null }>;
  httpErrors: Array<{ url: string; status: number }>;
};

export const test = base.extend<{ networkCapture: NetworkCapture }>({
  networkCapture: async ({ page }, use, testInfo) => {
    const requestFailed: NetworkCapture['requestFailed'] = [];
    const httpErrors: NetworkCapture['httpErrors'] = [];

    page.on('requestfailed', (req) => {
      const url = req.url();
      if (isAllowlisted('requestfailed', url, DEFAULT_ALLOWLIST)) return;
      requestFailed.push({ url, failure: req.failure()?.errorText ?? null });
    });

    page.on('response', (res) => {
      const url = res.url();
      const status = res.status();
      if (status < 400) return;
      if (isAllowlisted('status', url, DEFAULT_ALLOWLIST)) return;
      httpErrors.push({ url, status });
    });

    await use({ requestFailed, httpErrors });

    if (requestFailed.length > 0 || httpErrors.length > 0) {
      await testInfo.attach('network-errors.json', {
        body: JSON.stringify({ requestFailed, httpErrors }, null, 2),
        contentType: 'application/json',
      });
    }

    if (failOnRequestFailed && requestFailed.length > 0) {
      throw new Error(
        `Network requests failed:\n${requestFailed.map((r) => `${r.url} — ${r.failure}`).join('\n')}`
      );
    }

    if (failOnHttpError) {
      const serverErrors = httpErrors.filter((e) => e.status >= httpErrorThreshold);
      if (serverErrors.length > 0) {
        throw new Error(
          `Server errors detected:\n${serverErrors.map((e) => `${e.status} ${e.url}`).join('\n')}`
        );
      }
    }
  },
});

export { expect };
